# Copy this file to .env and fill values locally.
# Never commit .env or token files.

HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Official Terminal & SSH add-on access.
# If your add-on exposes a non-22 port, set it here.
HA_SSH_TARGET=homeassistant.local
HA_SSH_PORT=22
HA_REMOTE_CONFIG_DIR=/config

# Local mirror of the Home Assistant config.
HA_CONFIG_DIR=config

# Validation command to run on the Home Assistant host/add-on.
# Adjust if your shell exposes a different command.
HA_CHECK_CONFIG_COMMAND="ha core check --no-progress"
HA_CHECK_TIMEOUT_SECONDS=300

# Rsync excludes for config pull/deploy.
HA_RSYNC_EXCLUDES="secrets.yaml .storage .ha_run.lock home-assistant_v2.db* home-assistant.log* deps tts backups *.tar *.tar.gz"
